{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kill-team.schema.json",
  "title": "Kill Team Roster",
  "description": "Schema for a KT24 V3.0 kill team roster exported from official PDFs",
  "type": "object",
  "required": ["name", "faction", "operatives"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "name": {
      "type": "string",
      "description": "Display name of the kill team (e.g. 'Angels of Death')"
    },
    "faction": {
      "type": "string",
      "description": "Faction keyword as printed on datacards (e.g. 'Adeptus Astartes')"
    },
    "operatives": {
      "type": "array",
      "description": "All operative types available to this kill team",
      "minItems": 1,
      "items": { "$ref": "#/definitions/operative" }
    }
  },
  "definitions": {
    "operative": {
      "type": "object",
      "required": ["name", "operativeType", "stats", "weapons", "equipment"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Operative display name"
        },
        "operativeType": {
          "type": "string",
          "description": "Operative type key used for roster selection and DB import"
        },
        "stats": { "$ref": "#/definitions/stats" },
        "weapons": {
          "type": "array",
          "description": "All weapons available to this operative",
          "minItems": 1,
          "items": { "$ref": "#/definitions/weapon" }
        },
        "equipment": {
          "type": "array",
          "description": "Equipment names available to this operative (faction + universal)",
          "items": { "type": "string" }
        }
      }
    },
    "stats": {
      "type": "object",
      "required": ["move", "apl", "wounds", "save"],
      "additionalProperties": false,
      "properties": {
        "move": {
          "type": "integer",
          "description": "Move characteristic in inches (e.g. 6 for 6\")",
          "minimum": 1
        },
        "apl": {
          "type": "integer",
          "description": "Action Point Limit",
          "minimum": 1,
          "maximum": 5
        },
        "wounds": {
          "type": "integer",
          "description": "Wounds characteristic",
          "minimum": 1
        },
        "save": {
          "type": "string",
          "description": "Save characteristic (e.g. '3+')",
          "pattern": "^[2-6]\\+$"
        }
      }
    },
    "weapon": {
      "type": "object",
      "required": ["name", "type", "atk", "hit", "dmg", "specialRules"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Weapon name as printed on the datacard (e.g. 'Bolt rifle', 'Plasma pistol (standard)')"
        },
        "type": {
          "type": "string",
          "description": "Ranged or Melee",
          "enum": ["Ranged", "Melee"]
        },
        "atk": {
          "type": "integer",
          "description": "Attack dice count",
          "minimum": 1
        },
        "hit": {
          "type": "string",
          "description": "Hit threshold (e.g. '3+', '2+')",
          "pattern": "^[2-6]\\+$"
        },
        "dmg": {
          "type": "string",
          "description": "Damage as 'normal/critical' (e.g. '3/5')",
          "pattern": "^\\d+/\\d+$"
        },
        "specialRules": {
          "type": "string",
          "description": "Comma-separated special rules as printed (e.g. 'Range 8\", Piercing 1'). Empty string if none."
        }
      }
    }
  }
}
